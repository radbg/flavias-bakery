rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Acceso por bakeryId (UUID único, imposible de adivinar)
    match /bakeries/{bakeryId} {
      allow read, write: if true;
      match /{subcollection}/{docId} {
        allow read, write: if true;
      }
    }
  }
}
